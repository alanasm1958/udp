# Production Environment Variables
# Copy this to .env.prod and fill in your values

# Domain (for Caddy TLS)
DOMAIN=your-domain.com

# Database
POSTGRES_USER=udp
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=udp
DATABASE_URL=postgres://udp:CHANGE_ME_STRONG_PASSWORD@db:5432/udp

# Auth secret (REQUIRED — generate with: openssl rand -base64 32)
AUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# Encryption key for stored credentials (generate with: openssl rand -base64 32)
CREDENTIALS_ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL

# Session (generate with: openssl rand -base64 32)
SESSION_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# Cron job secret (generate with: openssl rand -base64 32)
CRON_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# Stripe (required for billing features)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...

# Backup settings
BACKUP_RETENTION_DAYS=7
